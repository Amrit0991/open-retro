{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": true,
    "skipLibCheck": true,
    "types": ["@cloudflare/workers-types"],
    "esModuleInterop": true,
    "composite": true,
    "emitDeclarationOnly": true,
    "outDir": "./.tsbuild"
  },
  "include": ["src", "test"],
  "references": [{ "path": "./tsconfig.node.json" }]
}
