{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022"],
    "strict": true,
    "noUnusedLocals": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "composite": true,
    "emitDeclarationOnly": true,
    "outDir": "./.tsbuild-node",
    "types": ["node"]
  },
  "include": ["vite.config.ts", "vitest.config.ts"]
}
